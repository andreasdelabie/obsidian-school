filters:
  and:
    - file.name != this.file.folder
    - file.folder == this.file.folder
views:
  - type: table
    name: All Notes
    filters:
      and:
        - file.ext == "md"
    order:
      - file.name
      - file.ctime
      - file.mtime
      - completed
    sort:
      - property: file.name
        direction: ASC
      - property: file.ctime
        direction: ASC
    columnSize:
      file.name: 200
      file.ctime: 200
      file.mtime: 200
      note.completed: 100
